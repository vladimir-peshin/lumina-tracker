# SteamGridDB (required for cover art search)
# Get your key at https://www.steamgriddb.com/profile/preferences/api
STEAMGRIDDB_API_KEY=your_steamgriddb_api_key_here

# Steam Import (optional, for scripts/import_steam.cjs)
# Get your key at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here
# Your 64-bit Steam ID. Find it at https://steamid.io/ or in your Steam profile URL
STEAM_ID=your_steam_id_here

# GOG Import (optional, for scripts/import_gog.cjs)
# Your GOG public profile username
GOG_USERNAME=your_gog_username_here

# Server port (optional, default 3001)
PORT=3001
